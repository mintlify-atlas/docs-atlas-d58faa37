  "colors": {
    "primary": "#040404",
    "light": "#5a8a00",
    "dark": "#040404"
  },
  "favicon": "https://media.brand.dev/4658f2bb-5669-447b-b7f3-397e461d996a.svg",
  "logo": {
    "light": "https://media.brand.dev/2c1cc983-2357-4e1c-8728-c7a619cb36b2.svg",
